{
  "name": "elevatorrobot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0 <=22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "npm run build && tsx scripts/analyze-bundle.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "deploy": "bash -c 'unset npm_config_prefix npm_lifecycle_script npm_lifecycle_event npm_execpath && source ~/.nvm/nvm.sh && nvm use 22 && npx ampx sandbox --identifier'",
    "deploy:default": "bash -c 'unset npm_config_prefix npm_lifecycle_script npm_lifecycle_event npm_execpath && source ~/.nvm/nvm.sh && nvm use 22 && npx ampx sandbox'",
    "associate-domain": "tsx scripts/associate-domain.ts",
    "optimize-images": "tsx scripts/optimize-images.ts"
  },
  "dependencies": {
    "@aws-amplify/api-graphql": "^4.7.3",
    "@aws-amplify/ui-react": "^6.5.5",
    "@aws-sdk/client-dynamodb": "^3.879.0",
    "@aws-sdk/client-ses": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.879.0",
    "aws-amplify": "^6.12.3",
    "aws-rum-web": "^1.25.0",
    "aws-sdk": "^2.1692.0",
    "flowbite": "^4.0.1",
    "flowbite-react": "^0.12.16",
    "lucide-react": "^0.562.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.13.0",
    "@aws-amplify/backend-cli": "^1.4.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "aws-cdk": "^2.176.0",
    "aws-cdk-lib": "^2.176.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-terminal": "^1.2.0",
    "vitest": "^4.1.4",
    "workbox-window": "^7.4.0"
  }
}
